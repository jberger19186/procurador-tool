# ============================================================
# PROCURADOR SCW — Variables de entorno del servidor
# Copiá este archivo como .env y completá los valores reales
# NUNCA subas el .env a git
# ============================================================

# ── Base de datos PostgreSQL ────────────────────────────────
DB_USER=procurador_user
DB_HOST=localhost
DB_NAME=procurador_db
DB_PASSWORD=REEMPLAZAR_CON_PASSWORD_SEGURO
DB_PORT=5432

# ── JWT y cifrado ───────────────────────────────────────────
# Generá con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REEMPLAZAR_CON_STRING_ALEATORIO_64_BYTES
ENCRYPTION_KEY=REEMPLAZAR_CON_STRING_ALEATORIO_64_BYTES
SESSION_KEY_SECRET=REEMPLAZAR_CON_STRING_ALEATORIO_64_BYTES

# ── Servidor ────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
HTTPS_PORT=3443

# ── SSL (Certbot los genera automáticamente) ────────────────
SSL_KEY_PATH=/etc/letsencrypt/live/api.procuradortool.com/privkey.pem
SSL_CERT_PATH=/etc/letsencrypt/live/api.procuradortool.com/fullchain.pem

# ── CORS ────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://api.procuradortool.com

# ── DigitalOcean Spaces (backups PostgreSQL) ────────────────
DO_SPACES_KEY=REEMPLAZAR_CON_ACCESS_KEY_DE_SPACES
DO_SPACES_SECRET=REEMPLAZAR_CON_SECRET_KEY_DE_SPACES
DO_SPACES_BUCKET=procurador-backups
DO_SPACES_REGION=nyc3
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com

# ── Better Stack / Logtail (logs centralizados) ─────────────
LOGTAIL_TOKEN=REEMPLAZAR_CON_SOURCE_TOKEN_DE_BETTERSTACK

# ── Alertas del canary test (email) ────────────────────────
ALERT_EMAIL_TO=REEMPLAZAR_CON_TU_EMAIL
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=REEMPLAZAR_CON_EMAIL_GMAIL
SMTP_PASS=REEMPLAZAR_CON_APP_PASSWORD_DE_GMAIL

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info

# ── Módulo de Pagos (Fase 5) ─────────────────────────────────
# Mantener en false hasta que las credenciales externas estén validadas
PAYMENT_MODULE_ENABLED=false
# CSV de user_ids habilitados para beta (ej: "6,12,15")
PAYMENT_BETA_USER_IDS=

# ── MercadoPago Argentina ─────────────────────────────────────
# Obtener en: https://www.mercadopago.com.ar/developers/panel/app
# Usar "Credenciales de prueba" para sandbox, "Credenciales de producción" para live
MP_ACCESS_TOKEN=REEMPLAZAR_CON_ACCESS_TOKEN_MP
MP_PUBLIC_KEY=REEMPLAZAR_CON_PUBLIC_KEY_MP
# Generado al configurar webhook en el panel MP → "Webhooks" → "Firma secreta"
MP_WEBHOOK_SECRET=REEMPLAZAR_CON_WEBHOOK_SECRET_MP
# Precios en ARS (centavos NO — pesos enteros)
MP_PLAN_EXTENSION_PROMO_PRICE=1500
MP_PLAN_COMBO_PROMO_PRICE=15000
# URL base para back_url de MercadoPago (sin slash final)
APP_BASE_URL=https://procuradortool.com

# ── Facturante (SOAP — Factura C Monotributista) ──────────────
# Obtener al contratar Pack 50 en https://www.facturante.com
FACTURANTE_WSDL_URL=REEMPLAZAR_CON_URL_WSDL_HOMOLOGACION
FACTURANTE_WSDL_URL_PROD=REEMPLAZAR_CON_URL_WSDL_PRODUCCION
FACTURANTE_EMPRESA=REEMPLAZAR_CON_NOMBRE_EMPRESA
FACTURANTE_USUARIO=REEMPLAZAR_CON_USUARIO_FACTURANTE
FACTURANTE_HASH=REEMPLAZAR_CON_HASH_FACTURANTE
FACTURANTE_PUNTO_VENTA=0001

# Email que recibe alertas si la emisión de facturas falla 3 veces
INVOICE_ADMIN_ALERT_EMAIL=jberger19186@gmail.com
